{
  "name": "attendance-tracker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0 --port 3000",
    "dev:http": "next dev --hostname 0.0.0.0 --port 3000",
    "dev:lan-qr": "node scripts/dev-with-qr.js",
    "build": "prisma generate && next build",
    "start": "prisma migrate deploy && next start --hostname 0.0.0.0 --port ${PORT:-3000}",
    "start:http": "next start --hostname 0.0.0.0 --port ${PORT:-3000}",
    "certs:setup": "bash scripts/setup-local-https.sh",
    "start:https-local": "node scripts/start-https.js",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke:http": "bash scripts/http-smoke.sh",
    "db:seed-demo": "npx tsx scripts/seed-demo.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "html5-qrcode": "^2.3.8",
    "next": "16.2.10",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.43",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "qrcode-terminal": "^0.12.0",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
