# PostgreSQL (local docker compose db service)
DATABASE_URL="postgresql://presentpo:presentpo@127.0.0.1:5432/presentpo?schema=public"

# Teacher gate (prefer TEACHER_PASSWORD; TEACHER_PIN still accepted as fallback)
TEACHER_PASSWORD="change-me"
# TEACHER_PIN="change-me"

EARLY_CHECKIN_MINUTES=15
TZ=Asia/Manila

# Public site URL (production: https://presentpo.com) — also drives cookie Secure + WebAuthn rpID
PUBLIC_APP_URL="http://localhost:3000"

# Optional / legacy (projector rotate — retiring with v0.2 teacher-scan)
# QR_ROTATE_SECONDS=20
